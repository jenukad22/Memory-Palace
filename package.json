{
  "name": "memory-palace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:bundle": "node scripts/bundle-migrations.mjs",
    "db:migrations": "npm run db:generate && npm run db:bundle",
    "prepare": "husky"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.2",
    "drizzle-orm": "0.45.2",
    "expo": "57.0.7",
    "expo-sqlite": "57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-web": "0.21.2",
    "sql.js": "1.13.0",
    "ts-fsrs": "^5.4.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/sql.js": "1.4.9",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.5",
    "eslint-config-expo": "57.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "3.10.1",
    "husky": "9.1.7",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
